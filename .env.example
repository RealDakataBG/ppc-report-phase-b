# Copy this file to .env for local `netlify dev` testing. Never commit the real .env file
# (it's already excluded via .gitignore). These same values also get set as Netlify
# environment variables later, in the deployed site's dashboard.

# Supabase Project Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# "anon" / "publishable" key - safe to expose, RLS is the real security boundary
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
# "service_role" / "secret" key - real secret, server-only, never sent to the browser
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Google service account JSON key file, base64-encoded into one line
# (Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("your-key.json")))
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=xxxxxxxxxxxxxxxxxxxxxxxx

# The to-do Google Sheet's id and gid (from its URL)
TODO_SHEET_ID=1mxKUuihxF5kZmar1FXHNI3btLsV8LuSxgoRp58zBkyA
TODO_SHEET_GID=0
